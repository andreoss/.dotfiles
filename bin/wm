#!/bin/sh
WM=

if type icewm-session; then
	WM="icewm-session --nobg"
elif type dwm; then
	WM=dwm
elif [ -d "$HOME"/.stumpwm.d ] && type sbcl; then
	WM="$HOME/.stumpwm.d/start.sh"
elif type ratpoison; then
	WM=ratpoison
else
	WM=xterm
fi

while :; do
    dunstify "Running '$WM'"
    $WM
    sleep 10
done

exit
